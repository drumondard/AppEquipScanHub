# Instala todas as dependências
npm install

# Compila o frontend React (Vite) e o servidor Express em dist/server.cjs
npm run build


 >> ## Execução Contínua com PM2

 # Instalar o PM2 globalmente (caso ainda não possua)
sudo npm install -g pm2

# Iniciar a aplicação
pm2 start dist/server.cjs --name "appequipscan"

# Salvar o estado do PM2 para inicialização automática no boot
pm2 save
pm2 startup


